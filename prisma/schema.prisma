generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int       @id @default(autoincrement())
  spotifyId       String    @unique
  displayName     String?
  email           String?
  profileImageUrl String?
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  topTracks            UserTopTrack[]
  topArtists           UserTopArtist[]
  listeningHistory     ListeningHistory[]
  savedRecommendations SavedRecommendation[]
}

model UserTopTrack {
  id             Int      @id @default(autoincrement())
  userId         Int
  spotifyTrackId String
  trackName      String
  artistNames    String
  albumImageUrl  String?
  rank           Int
  timeRange      String   @default("medium_term")
  fetchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spotifyTrackId, timeRange])
}

model UserTopArtist {
  id              Int      @id @default(autoincrement())
  userId          Int
  spotifyArtistId String
  artistName      String
  imageUrl        String?
  genres          String[]
  rank            Int
  timeRange       String   @default("medium_term")
  fetchedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spotifyArtistId, timeRange])
}

model ListeningHistory {
  id             Int      @id @default(autoincrement())
  userId         Int
  spotifyTrackId String
  trackName      String
  artistNames    String
  albumImageUrl  String?
  durationMs     Int?     @default(0)
  playedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, spotifyTrackId])
}

model SavedRecommendation {
  id            Int      @id @default(autoincrement())
  userId        Int
  spotifyId     String // Can be track ID or artist ID
  name          String
  type          String // 'track' or 'artist'
  artistNames   String? // For tracks
  albumImageUrl String?
  genres        String[] // For artists
  previewUrl    String? // For tracks
  popularity    Int?
  savedAt       DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spotifyId, type])
  @@index([userId])
  @@index([userId, type])
}
